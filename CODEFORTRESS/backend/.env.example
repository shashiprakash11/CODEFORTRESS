# ─── CodeFortress CI — Environment Variables ───
# Copy this file to .env and fill in your values

# Port (Railway/Render set this automatically)
PORT=4000

# Anthropic API Key — for AI auto-fix feature
# Get free key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Token — for scanning private repos + creating PRs
# Create at: https://github.com/settings/tokens (needs 'repo' scope)
GITHUB_TOKEN=your_github_token_here

# Environment
NODE_ENV=development
